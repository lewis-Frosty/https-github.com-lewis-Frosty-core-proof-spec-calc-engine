# ── Shopify Storefront API ───────────────────────────────────────────────
# Copy this file to `.env.local` and fill in your Storefront API token.
# The site renders with illustrative fallback data until these are set.

# Your store's myshopify.com domain (no https://)
SHOPIFY_STORE_DOMAIN=iywheq-m4.myshopify.com

# Public Storefront API access token.
# Create one in Shopify admin → Settings → Apps and sales channels →
# Develop apps → Create an app → Configure Storefront API scopes
# (unauthenticated_read_product_listings, unauthenticated_read_product_inventory,
#  unauthenticated_write_checkouts, unauthenticated_read_checkouts) → Install →
# "API credentials" → Storefront API access token.
SHOPIFY_STOREFRONT_API_TOKEN=

# Storefront API version
SHOPIFY_STOREFRONT_API_VERSION=2025-01

# The handle of the flagship product
SHOPIFY_PRODUCT_HANDLE=sealyn-lining-tile
